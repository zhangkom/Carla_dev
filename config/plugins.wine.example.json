{
  "carla_root": "/app",
  "python": "/usr/local/bin/wine-python",
  "renderer_path_mode": "wine",
  "ffmpeg": "C:\\ffmpeg\\bin\\ffmpeg.exe",
  "output_dir": "/app/output",
  "work_dir": "/app/service_work",
