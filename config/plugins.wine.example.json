{
  "carla_root": "/app",
  "python": "python3",
  "renderer_path_mode": "native_bridge",
  "plugin_load_mode": "load_file",
  "carla_backend": "/opt/carla-service/bin/libcarla_standalone2.so",
  "carla_bin_dir": "/opt/carla-service/bin",
  "carla_resources_dir": "/opt/carla-service/bin/resources",
  "carla_frontend_dir": "/opt/carla-service/source/frontend",
  "ffmpeg": "ffmpeg",
  "output_dir": "/app/output",
  "work_dir": "/app/service_work",
  "render_timeout_seconds": 900,
  "audio": {
    "driver": "Dummy",
    "device": "",
    "buffer_size": 512,
    "sample_rate": 44100
  },
  "encoding": {
    "mp3_mode": "cbr",
    "mp3_bitrate": "320k",
    "mp3_sample_rate": 44100,
    "mp3_channels": 2,
    "mp3_quality": 2,
    "mp3_compression_level": 7,
    "mp3_id3v2_version": 3
  },
  "plugins": [
    {
      "id": "kong_qin_rv",
      "name": "Qin_RV",
      "type": "vst2",
      "path": "/wineprefix/drive_c/VSTPlugins/KongAudio/Qin_RV.DLL",
      "enabled": true,
      "notes": "Ubuntu container profile for Linux Carla + official win32 Wine bridge. Use Qin_RV.dll directly; Qin_RV_x64.dll is only a 64-bit wrapper and was silent under Wine."
    },
    {
      "id": "sf2_musyng_kite",
      "name": "Musyng Kite",
      "type": "sf2",
      "path": "/app/assets/soundfont2/Musyng_Kite.sf2",
      "label": "Musyng_Kite",
      "enabled": true,
      "notes": "General MIDI SoundFont profile rendered by Carla FluidSynth. Preserve MIDI channels and program changes."
    }
  ],
  "styles": [
    {
      "id": "kong_gaohu_sus_leg_mw",
      "plugin_id": "kong_qin_rv",
      "name": "Kong GaoHu Sus Leg MW",
      "instrument": "ChineeGaoHu",
      "articulation": "Sus_Leg_1_MW",
      "enabled": true,
      "state": "states/kong_gaohu_sus_leg_mw.carxs",
      "parameters": [],
      "midi_policy": {
        "enabled": true,
        "target_channel": 1,
        "remove_program_changes": true,
        "remove_bank_select": true,
        "keep_control_changes": [1, 7, 10, 11, 64],
        "keep_pitch_bend": true,
        "keep_note_aftertouch": true,
        "keep_channel_pressure": true,
        "keep_sysex": false
      }
    },
    {
      "id": "kong_gaohu_stac_1",
      "plugin_id": "kong_qin_rv",
      "name": "Kong GaoHu Stac 1",
      "instrument": "ChineeGaoHu",
      "articulation": "Stac_1",
      "enabled": true,
      "state": "states/kong_gaohu_stac_1.carxs",
      "parameters": [],
      "midi_policy": {
        "enabled": true,
        "target_channel": 1,
        "remove_program_changes": true,
        "remove_bank_select": true,
        "keep_control_changes": [1, 7, 10, 11, 64],
        "keep_pitch_bend": true,
        "keep_note_aftertouch": true,
        "keep_channel_pressure": true,
        "keep_sysex": false
      }
    },
    {
      "id": "kong_gaohu_trill_vel_1",
      "plugin_id": "kong_qin_rv",
      "name": "Kong GaoHu Trill Vel 1",
      "instrument": "ChineeGaoHu",
      "articulation": "Trill_Vel_1",
      "enabled": true,
      "state": "states/kong_gaohu_trill.carxs",
      "parameters": [],
      "midi_policy": {
        "enabled": true,
        "target_channel": 1,
        "remove_program_changes": true,
        "remove_bank_select": true,
        "keep_control_changes": [1, 7, 10, 11, 64],
        "keep_pitch_bend": true,
        "keep_note_aftertouch": true,
