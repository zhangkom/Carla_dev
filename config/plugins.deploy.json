{
  "_file_info": {
    "File name": "plugins.deploy.json",
    "Brief": "Ubuntu 自包含部署插件配置",
    "Function": "定义 MGSC DAW FastAPI 服务在容器内使用的 Kong Audio 和 SoundFont 插件风格配置",
    "Author": "咪咕数创工程架构组 / MGSC AI Software Architecture group",
    "Version": "V2.5.10",
    "Date": "2026/04/30"
  },
  "carla_root": "/home/workspace",
  "python": "python3",
  "renderer_path_mode": "native_bridge",
  "plugin_load_mode": "load_file",
  "carla_backend": "/opt/carla-service/bin/libcarla_standalone2.so",
  "carla_bin_dir": "/opt/carla-service/bin",
  "carla_resources_dir": "/opt/carla-service/bin/resources",
  "carla_frontend_dir": "/opt/carla-service/source/frontend",
  "ffmpeg": "ffmpeg",
  "output_dir": "/home/runtime/output",
  "work_dir": "/home/runtime/service_work",
  "render_timeout_seconds": 900,
  "audio": {
    "driver": "Dummy",
    "device": "",
    "buffer_size": 512,
    "sample_rate": 44100
  },
  "encoding": {
    "mp3_bitrate": "320k",
    "mp3_sample_rate": 44100,
    "mp3_channels": 2,
    "mp3_id3v2_version": 3
  },
  "plugins": [
    {
      "id": "kong_qin_rv",
      "name": "Qin_RV",
      "type": "vst2",
      "path": "/wineprefix/drive_c/VSTPlugins/KongAudio/Qin_RV.DLL",
      "enabled": true,
      "notes": "Self-contained deployment profile for Linux Carla plus official win32 Wine bridge. Use Qin_RV.DLL directly; Qin_RV_x64.DLL was silent under Wine in this environment."
    },
    {
      "id": "sf2_musyng_kite",
      "name": "Musyng Kite",
      "type": "sf2",
      "path": "/home/workspace/assets/soundfont2/Musyng_Kite.sf2",
      "label": "Musyng_Kite",
      "enabled": true,
      "notes": "General MIDI SoundFont profile rendered by Carla FluidSynth. Preserve MIDI channels and program changes."
    },
    {
      "id": "vst_keyzone_classic",
      "name": "Keyzone Classic",
      "type": "vst2",
      "path": "/wineprefix/drive_c/VSTPlugins/Keyzone Classic/Keyzone Classic.dll",
      "enabled": true,
      "notes": "x64 VST2 piano plugin. Requires carla-bridge-win64.exe and plugin directory materialized under Wine C:\\VSTPlugins."
    },
    {
      "id": "vst_dsk_saxophones",
      "name": "DSK Saxophones",
      "type": "vst2",
      "path": "/wineprefix/drive_c/VSTPlugins/DSK Saxophones/DSK Saxophones.dll",
      "enabled": true,
      "notes": "x64 VST2 saxophone plugin. Requires carla-bridge-win64.exe and plugin directory materialized under Wine C:\\VSTPlugins."
    },
    {
      "id": "vst_sonatina_orchestra",
      "name": "Sonatina Orchestra",
      "type": "vst2",
      "path": "/wineprefix/drive_c/VSTPlugins/Sonatina Orchestra/Sonatina Orchestra.dll",
      "enabled": true,
      "notes": "x64 VST2 orchestra plugin. Requires carla-bridge-win64.exe and plugin directory materialized under Wine C:\\VSTPlugins."
    }
  ],
